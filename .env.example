# === Required ===
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DATABASE=HowNotToKillYourPlants
JWT_SECRET=generate-a-secure-random-string-at-least-32-chars

# === Collections (optional) ===
MONGO_USER_PROFILES_COLLECTION=UserCollection
MONGO_USER_GARDEN_COLLECTION=User_Garden_Collection
PLANT_DEATH_COLLECTION=PlantDeathCollection
PLANT_MONGO_COLLECTION=PlantCollection
MONGO_TOKEN_BLACKLIST_COLLECTION=TokenBlacklist

# === ML & APIs ===
VOYAGE_API_KEY=
COHERE_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
VECTOR_SEARCH_INDEX=vector_index

# === Production (set when deploying) ===
# Frontend URL - used by backend for CORS
CORS_ORIGINS=https://your-app.vercel.app
# Backend URL - used by frontend to call API
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# === Optional ===
USE_RERANK=true
USE_DEATH_PENALTY=true
DEATH_PENALTY_LAMBDA=0.5
USE_GEMINI=true
GEMINI_MODEL=gemini-2.5-flash
USE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379/0
